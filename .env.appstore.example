# Google Play Console Configuration
# ================================
# Follow these steps to enable Google Play install metrics:
# 1. Go to Google Play Console → Settings → API access
# 2. Create a service account and download JSON credentials
# 3. Set the path to your service account JSON file below

GOOGLE_PLAY_SERVICE_ACCOUNT_PATH=./path/to/google-play-service-account.json

# App Store Connect Configuration
# ================================
# Follow these steps to enable App Store install metrics:
# 1. Go to App Store Connect → Users and Access → Integrations → App Store Connect API
# 2. Create a new API key and note the Key ID, Issuer ID
# 3. Download the private key file (.p8)
# 4. Fill in the values below

APPSTORE_KEY_ID=your_app_store_key_id_here
APPSTORE_ISSUER_ID=your_app_store_issuer_id_here
APPSTORE_PRIVATE_KEY_PATH=./path/to/private-key.p8
APPSTORE_APP_ID=your_app_store_app_id_here

# Example App Store App IDs:
# - If your App Store URL is: https://apps.apple.com/app/diaryfi/id1234567890
# - Your App ID would be: 1234567890
